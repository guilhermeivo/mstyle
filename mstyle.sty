\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{mstyle}[2025/01/03 v0.1 (guilhermeivo)]
\typeout{Document Style: Layout definitions for package mstyle}

% \RequirePackage{newtx} % pattern font in projects

\RequirePackage{mstyle-core}
\RequirePackage{microtype}

\linespread{1.25} 
\setlength{\parskip}{5pt}

\newif\ifmstyle@customsection
\newif\ifmstyle@custommaketitle
\newif\ifmstyle@customlistings
\newif\ifmstyle@margin
\mstyle@margintrue

\DeclareOption{section}{\mstyle@customsectiontrue}
\DeclareOption{maketitle}{\mstyle@custommaketitletrue}
\DeclareOption{nomargin}{\mstyle@marginfalse}
\ProcessOptions\relax

\if@twocolumn%
    \setlength{\parindent}{0.75cm}
    \setlength{\columnsep}{0.6cm} 
\else% \@twocolumnfalse
    \@ifpackageloaded{multicol}{
        \setlength{\parindent}{0.75cm}
        \setlength{\columnsep}{0.6cm}
    }{
        \setlength{\parindent}{1.5cm}
    }
\fi

%% CUSTOM SECTION ENVIRONMENT BEGIN
\ifmstyle@customsection

\ifmstyle@margin
    \RequirePackage[
        left=2.5cm, 
        right=2.0cm, 
        top=2.5cm, 
        bottom=2.0cm
    ]{geometry}
\fi

\let\my@ssect\@ssect

\ifdefined\HCode

\def\@ssect#1#2#3#4#5{%
    \my@ssect{#1}{#2}{#3}{#4}{#5}}
\else
\def\@ssect#1#2#3#4#5{%
    %\phantomsection%
    %\addcontentsline{toc}{#1}{\protect\numberline{}#7}

    \my@ssect{#1}{#2}{#3}{#4}{#5}%
    %%
    \if@twocolumn%
        \ifnum\col@number=\@ne\relax%
            \let\@upperletter\relax%
        \else%
            \relax%
        \fi%
    \fi%
    \@upperletter}

\renewcommand{\section}{\@startsection{section}{1}{\z@}%
    {-3.5ex \@plus -1ex \@minus -.2ex}%
    {2.3ex \@plus .2ex}%
    {\normalfont\LARGE\scshape\bfseries\centering}%
}

\renewcommand{\subsection}{\@startsection{subsection}{2}{\z@}%
    {-3.25ex\@plus -1ex \@minus -.2ex}%
    {1.5ex \@plus .2ex}%
    {\normalfont\Large\scshape\bfseries\centering}%
}

\renewcommand{\subsubsection}{\@startsection{subsubsection}{3}{\z@}%
    {-3.25ex\@plus -1ex \@minus -.2ex}%
    {1.5ex \@plus .2ex}%
    {\normalfont\large\scshape\bfseries\centering}%
}

\fi

\fi
%% CUSTOM SECTION ENVIRONMENT END

%% CUSTOM MAKETITLE ENVIRONMENT BEGIN
\let\titleoriginal\title
\renewcommand{\title}[1]{
    \titleoriginal{#1}%
    \newcommand{\thetitle}{#1}
}
\newcommand*{\subtitle}[1]{\gdef\@subtitle{#1}}
\newcommand*{\accessin}[1]{\gdef\@accessin{#1}}
\newcommand*{\keywords}[1]{\gdef\@keywords{#1}}

\ifmstyle@custommaketitle

\renewcommand{\@maketitle}{%
    \cleardoublepage
    \null
    \vskip 2em%
    \begin{center}%
        \let \footnote \thanks
        {\LARGE \textbf{\@title} \par}%
        \ifdefined\@subtitle%
            {\LARGE \@subtitle \par}%
        \fi
        \vskip 1em%
        {\large
            \lineskip .5em%
            \begin{tabular}[t]{c}%
            \ifdefined\@accessin%
            \@accessin \\
            \fi
            \ifdefined\@author%
            \@author  \\
            \fi
            \end{tabular}\par}%
        \vskip 1em%
        \ifdefined\@date
        {\large \@date}
        \fi
    \end{center}%
    \par
    \vskip 1.5em
}

\let\mymaketitle\maketitle

\renewcommand{\maketitle}{
    \newgeometry{left=2.5cm, right=2.0cm, top=2.5cm, bottom=2.0cm}
    \renewcommand{\thepage}{Cover}%
    \mymaketitle%
    \thispagestyle{empty}%
    \restoregeometry
}

\fi
%% CUSTOM MAKETITLE ENVIRONMENT END

%% CUSTOM HEADINGS ENVIRONMENT BEGIN
\def\ps@mainheadings{%
    \def\@oddhead{\hspace*{-1cm}\reset@font\footnotesize{\slshape{\thetitle}}\hfill\thepage\hspace*{-3cm}}%
    \def\@evenhead{\hspace*{-3cm}\reset@font\footnotesize\thepage\hfill\hspace*{-1cm}}%
    \let\@oddfoot\@empty
    \let\@evenfoot\@empty
}
%% CUSTOM HEADINGS ENVIRONMENT END

