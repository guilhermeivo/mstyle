% configuration math names
\@ifpackageloaded{amsmath}{
    \DeclareMathOperator{\arctg}{arctg}
    \renewcommand{\arctan}{\arctg}

    \DeclareMathOperator{\sen}{sen}
    \renewcommand{\sin}{\sen}
